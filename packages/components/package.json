{
  "name": "@pulseai/components",
  "version": "0.1.2",
  "description": "Lit-based Web Component library for the PulseAI Design System",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": "./dist/*"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "sideEffects": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "web-test-runner --config web-test-runner.config.mjs",
    "test:watch": "web-test-runner --config web-test-runner.config.mjs --watch",
    "analyze": "custom-elements-manifest analyze --litelement --outdir ."
  },
  "dependencies": {
    "@pulseai/tokens": "workspace:*",
    "lit": "^3.2.0"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.10.4",
    "@open-wc/testing": "^4.0.0",
    "@web/dev-server-esbuild": "^2.0.0",
    "@web/test-runner": "^0.19.0",
    "@web/test-runner-playwright": "^0.11.0",
    "axe-core": "^4.10.0",
    "typescript": "^5.5.4"
  }
}
